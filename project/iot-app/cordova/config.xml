<?xml version='1.0' encoding='utf-8'?>
<widget id="com.hitek.humiture" version="1.0.0" xmlns="http://www.w3.org/ns/widgets" xmlns:cdv="http://cordova.apache.org/ns/1.0" xmlns:android="http://schemas.android.com/apk/res/android">
    <name>智慧温湿度</name>
    <description>海特智慧试验室 - 智慧温湿度系统</description>
    <author email="dev@hiteksoft.com" href="http://hiteksoft.com/">hiteksoft</author>
    <platform name="android">
        <icon src="resources/icon.png"/>
        <preference name="AndroidWindowSplashScreenAnimatedIcon" value="resources/start.xml" />
        <edit-config file="app/src/main/AndroidManifest.xml" mode="merge" target="/manifest/application">
            <application android:usesCleartextTraffic="true" />
        </edit-config>
        <hook type="after_plugin_install" src="scripts/android/syncCordovaPlugins.bat" />
    </platform>
    <content src="https://static.ilis.cn/iot/index.html"/>
    <!-- <content src="index.html"/> -->
    <access origin="*" />
    <allow-navigation href="*" />
    <allow-intent href="http://*/*" />
    <allow-intent href="https://*/*" />
</widget>
